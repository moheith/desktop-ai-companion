{
  "name": "desktop-mascot",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.you.desktop-mascot",
    "productName": "Desktop Mascot",
    "extraResources": [
      {
        "from": "mic",
        "to": "mic"
      }
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^6.0.0"
  },
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^24.13.3"
  }
}
